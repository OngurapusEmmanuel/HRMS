# Postgres connection (Supabase, Neon, RDS, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/hr_system?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/hr_system?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# File storage — "local" (default, disk under public/uploads) or "s3"
# (AWS S3, Cloudflare R2, or GCS via its S3-compatible API). See lib/storage.ts.
STORAGE_PROVIDER="local"
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=              # only for R2/GCS — omit for real AWS S3
# S3_PUBLIC_URL_BASE=       # optional, e.g. a CDN domain in front of the bucket

# Email — unset means emails are logged to the console instead of sent.
# See lib/email.ts for the provider switch (Resend shown; SES is similarly wired).
EMAIL_PROVIDER="console"
# RESEND_API_KEY=
# EMAIL_FROM="hr@example.com"
